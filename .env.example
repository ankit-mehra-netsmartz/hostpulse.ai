# HostPulse.ai Environment Variables
# Copy this file to .env and fill in the values.

# ======================
# Required
# ======================
DATABASE_URL=postgresql://user:password@localhost:5432/hostpulse
SESSION_SECRET=  # Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"

# ======================
# Server
# ======================
NODE_ENV=development
PORT=5000
APP_URL=http://localhost:5000

# ======================
# Google OAuth
# ======================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/auth/google/callback

# ======================
# AI Integrations
# ======================
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=

AI_INTEGRATIONS_OPENROUTER_API_KEY=
AI_INTEGRATIONS_OPENROUTER_BASE_URL=

AI_INTEGRATIONS_GEMINI_API_KEY=
AI_INTEGRATIONS_GEMINI_BASE_URL=

ELEVENLABS_API_KEY=

# ======================
# Hospitable OAuth
# ======================
HOSPITABLE_CLIENT_ID=
HOSPITABLE_CLIENT_SECRET=
HOSPITABLE_WEBHOOK_SECRET=
# Dev overrides (optional)
HOSPITABLE_CLIENT_ID_DEV=
HOSPITABLE_CLIENT_SECRET_DEV=
HOSPITABLE_REDIRECT_URI_DEV=
HOSPITABLE_WEBHOOK_SECRET_DEV=

# ======================
# Notion OAuth
# ======================
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
# Dev overrides (optional)
NOTION_CLIENT_ID_DEV=
NOTION_CLIENT_SECRET_DEV=
NOTION_REDIRECT_URI_DEV=

# ======================
# Twilio (SMS)
# ======================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ======================
# Resend (Email)
# ======================
HOSTPULSE_RESEND_API_KEY=
HOSTPULSE_RESEND_FROM=noreply@hostpulse.ai
HOSTPULSE_BASE_URL=http://localhost:5000

# ======================
# Database SSL (optional)
# ======================
# DATABASE_SSL_REJECT_UNAUTHORIZED=false  # Only set to false for self-signed certs
